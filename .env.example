# Copie este arquivo para ".env" e preencha com os valores reais.
# DATABASE_URL e DIRECT_URL vêm do painel do Neon (Connection string "Pooled" e "Direct", respectivamente).
DATABASE_URL="postgresql://usuario:senha@host-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require"
JWT_SECRET="troque-este-segredo-antes-de-publicar"
PORT=4000

# Necessário só em desenvolvimento local, se for testar upload de materiais.
# Em produção o Vercel injeta essa variável automaticamente ao conectar o Blob Storage.
BLOB_READ_WRITE_TOKEN=""
